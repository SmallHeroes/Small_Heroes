{
  "buildCommand": "prisma generate && next build",
  "functions": {
    "app/api/generate/route.ts": {
      "maxDuration": 300
    },
    "app/api/generate/worker/route.ts": {
      "maxDuration": 300
    },
    "app/api/generate/start/route.ts": {
      "maxDuration": 60
    },
    "app/api/generate/cron/sweep/route.ts": {
      "maxDuration": 60
    },
    "app/api/generate/cron/outbox/route.ts": {
      "maxDuration": 60
    },
    "app/api/generate/cron/exceptions/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/generate/cron/sweep",
      "schedule": "*/3 * * * *"
    },
    {
      "path": "/api/generate/cron/outbox",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/generate/cron/exceptions",
      "schedule": "*/2 * * * *"
    }
  ]
}
