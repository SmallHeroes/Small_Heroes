# Database (Prisma runtime should use pooled connection string)
# Supabase recommended setup:
# - DATABASE_URL: Supavisor / pooler URL (IPv4-friendly, port 6543)
# - DIRECT_URL: direct Postgres URL (port 5432), used by Prisma migrate/introspection
# Example placeholders (replace with your real Supabase values from Project Settings > Database > Connection string):
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
DATABASE_URL="postgresql://user:password@localhost:5432/small_heroes?sslmode=disable"
DIRECT_URL="postgresql://user:password@localhost:5432/small_heroes?sslmode=disable"

# Payments
PAYMENT_PROVIDER="payme" # "payme" | "stripe" | "fake"
# Fake payment is dev/staging only and must never be enabled in production.
ENABLE_FAKE_PAYMENT="false"
# Set to true ONLY for local development builds that run with NODE_ENV=production (e.g. `next build`).
# Never enable in real production deploys.
ALLOW_FAKE_PAYMENTS="false"

# PayMe (required when PAYMENT_PROVIDER=payme)
# Sandbox: https://sandbox.payme.io/api — Production: https://live.payme.io/api
PAYME_API_BASE_URL="https://sandbox.payme.io/api"
# If PayMe returns a path-only sale URL, set this to the public PayMe payment host (no trailing slash).
# Otherwise path-only URLs resolve against PAYME_API_BASE_URL.
# PAYME_CHECKOUT_PAGE_ORIGIN="https://pay.sandbox.payme.example"
# PAYME_API_KEY is your seller_payme_id from the PayMe dashboard (e.g. MPL…), sent as seller_payme_id in API bodies.
PAYME_API_KEY="MPL_your_seller_payme_id"
PAYME_WEBHOOK_SECRET="payme_webhook_secret"
# Optional fallback verification if signature is unavailable (comma-separated)
PAYME_WEBHOOK_ALLOWED_IPS=""
# Production default should stay false: require valid signature.
PAYME_WEBHOOK_ALLOW_IP_FALLBACK="false"
# DEV ONLY: when true, redirect query may be trusted as paid if verification is unavailable.
# Never enable in production.
PAYME_REDIRECT_TRUST_MODE="false"

# Stripe (required when PAYMENT_PROVIDER=stripe)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# App URL (no trailing slash)
# APP_URL is accepted as runtime alias. NEXT_PUBLIC_APP_URL remains the primary key.
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI Providers (at least one required for story generation)
OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."   # optional: alternative story provider
STORY_PROVIDER="openai"            # "openai" | "claude"
# Story generation model — Pro models use Responses API with reasoning
# gpt-5.3-pro may not be publicly listed; availability depends on project access.
STORY_MODEL="gpt-5.3-pro"
STORY_REASONING_EFFORT="xhigh"      # "medium" | "high" | "xhigh"
STORY_VERBOSITY="high"              # "low" | "medium" | "high"

# Optional fallback. Leave empty to fail loudly if STORY_MODEL is unavailable.
FALLBACK_STORY_MODEL=""

# Cheaper model for non-story pipeline stages (visual bible, image prompts, QA)
PIPELINE_SUPPORT_MODEL="gpt-5.3-chat-latest"

# Image generation (at least one required)
# Image provider: replicate (Flux / LoRA) | gpt-image (OpenAI GPT Image) | dall-e-3
IMAGE_PROVIDER="gpt-image"

# GPT Image quality (only when IMAGE_PROVIDER=gpt-image): low | medium | high
GPT_IMAGE_QUALITY="high"

REPLICATE_API_TOKEN="r8_..."       # required when IMAGE_PROVIDER=replicate
# Image model routing:
# - if IMAGE_MODEL_OVERRIDE is set, it takes strict priority in every environment
# - otherwise development mode uses REPLICATE_IMAGE_MODEL_DEVELOPMENT (Flux dev — LoRA-compatible)
# - production mode: uses REPLICATE_IMAGE_MODEL_PRODUCTION
IMAGE_MODEL_OVERRIDE="" # optional, e.g. flux_pro
REPLICATE_IMAGE_MODEL_DEVELOPMENT="black-forest-labs/flux-dev"
REPLICATE_IMAGE_MODEL_PRODUCTION="black-forest-labs/flux-2-pro"

# When true, final book page images (not cover, not story-direction previews) use lib/visualDirector
# for prompt composition instead of the legacy buildImagePrompt / STYLE_CONTRACT stack. Default: off.
USE_VISUAL_DIRECTOR="false"
# When "false", page images are persisted without post-processing
# (no smart crop, no paper fade integration). Reader falls back to raw URL.
# Default "true" preserves existing pipeline behavior.
ENABLE_PRESENTATION_POSTPROCESS="true"

SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..." # service role key with storage write access
SUPABASE_STORAGE_BUCKET="book-images"

# Audio (required if audioEnabled orders are supported)
ELEVENLABS_API_KEY="..."

# Email (required for ready-notification emails)
RESEND_API_KEY="re_..."

# Manual generation trigger protection
GENERATION_SECRET="some-random-secret"
