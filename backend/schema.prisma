// Prisma Schema — גיבורים קטנים
// Run: npx prisma generate && npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────
enum OrderStatus {
  draft
  pending_payment
  paid
  generating
  ready
  failed
  partial // story+images ready but audio failed
  needs_human_qa // book rendered but held from customer delivery pending human QA (e.g. low-confidence anchor)
}

enum GenerationStatus {
  pending
  running
  done
  failed
}

enum StoryDirectionArchetype {
  bedtime
  adventure
  fantasy
}

enum StoryDirectionSetStatus {
  pending
  ready
  selected
  failed
}

enum StoryLength {
  short   // 10 pages (bedtime tier)
  medium  // 15 pages (adventure tier)
  long    // 20 pages (fantasy tier)
}

enum IllustrationStyle {
  pencil_watercolor
  realistic_illustrated
  whimsical_comic_fantasy
  detailed_whimsical_world
  // Legacy — kept to avoid DB migration failures on old rows
  clean_cartoon_2d
  soft_3d_animation
  illustrative_classic
  realistic_cartoon
}

// Phase-1 base_book_integrity — readiness/fulfillment lifecycles (flag READINESS_MANIFEST_ENABLED, default OFF).
enum ReadinessStatus {
  pending
  passed
  blocked
  stale
}

enum DeliveryOutboxStatus {
  scheduled
  processing
  sent
  failed
  suppressed             // legacy (pre-P1-f live-recheck path); no longer produced
  superseded             // legacy (P1-f #3, pre-split); no longer produced
  // (P1-f #3h-D) Recovery taxonomy. A CAS mismatch is NEVER a business revocation — it is a recoverable
  // not-yet-deliverable state. The worker (CAS) may only ever write the two RECOVERABLE terminals below.
  delivery_blocked       // CAS mismatch: order not ready (paid/generating/needs_human_qa/partial are all TRANSIENT),
  //                        readiness not passed, or inputs_stale. RECOVERABLE → a re-commit rebinds this row,
  //                        but ONLY while sendAttempted=false (a post-send blocked row needs reconciliation).
  superseded_by_manifest // defense-in-depth / protocol-drift: a newer VALID manifest owns the order (ready+passed,
  //                        different manifestId). RECOVERABLE via the re-commit rebind. Not a normal-flow path.
  invalid_payload        // payload-integrity recompute mismatch (corrupt/tampered row). NOT a business revocation;
  //                        needs investigation → reconciliation, never auto-revived.
  delivery_revoked       // RESERVED for an explicit domain action (cancellation/refund). The CAS NEVER writes this;
  //                        no writer exists yet. NOT auto-recoverable → explicit reconciliation/redelivery.
}

// ─── Customer ─────────────────────────────────────────
model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

// ─── WizardSession ────────────────────────────────────
// Stores raw wizard input before order creation
model WizardSession {
  id        String   @id @default(cuid())
  sessionId String   @unique  // browser session ID
  data      Json                // full wizard state blob
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order?
}

// ─── Order ────────────────────────────────────────────
model Order {
  id              String      @id @default(cuid())
  status          OrderStatus @default(draft)

  // Customer
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id])
  userId          String?
  user            UserAccount? @relation(fields: [userId], references: [id])
  customerEmail   String
  customerName    String

  // Child / story config
  childName         String
  childAge          Int?
  childGender       String?
  childTraits       String[]
  childSuperpower   String?   // single hero trait selected in wizard
  bookName          String?   // optional custom book title from wizard
  dedication        String?   @db.VarChar(300)
  childImageUrl     String?
  characterAnchors  Json?
  familyContext     Json?     // { parent1, parent2, sibling, homeText } — optional, from wizard step 4

  // Story parameters
  topic           String
  challengeItems  String[]
  challengeFree   String?
  outcomeItems    String[]
  outcomeFree     String?
  helperItems     String[]
  helperFree      String?
  avoidItems      String[]
  avoidFree       String?

  // Product configuration
  storyLength        StoryLength       @default(medium)
  /** Wizard package tier: bedtime | adventure | fantasy (matches pricing + page count). */
  storyDirection     String?
  coverImageUrl      String?
  illustrationStyle  IllustrationStyle @default(pencil_watercolor)
  audioEnabled       Boolean           @default(false)
  selectedVoice      String?
  sleepMode          Boolean           @default(false)
  pdfEnabled         Boolean           @default(false)
  bundleEnabled      Boolean           @default(false)
  videoEnabled       Boolean           @default(false)

  // Pricing
  basePrice          Int   // in agorot (ILS cents)
  addonsPrice        Int
  totalPrice         Int

  // Stripe
  stripeSessionId    String?  @unique
  stripePaymentId    String?
  stripePaid         Boolean  @default(false)
  stripeMetadata     Json?

  // Generic payment tracking (PayMe-first)
  paymentProvider    String?
  paymentId          String?
  paymeTransactionId String?  @unique
  paymeMetadata      Json?

  // Generation tracking
  textStatus         GenerationStatus @default(pending)
  imageStatus        GenerationStatus @default(pending)
  audioStatus        GenerationStatus @default(pending)
  packageStatus      GenerationStatus @default(pending)

  // Delivery hold: when status == needs_human_qa, why it was held (e.g.
  // "anchor_low_confidence:soft_band"). Cleared/ignored once QA releases to ready.
  deliveryHoldReason String?

  // Phase-1 base_book_integrity — FROZEN product-truth. Set once at order-creation + text-finalization;
  // the integrity gate reads ONLY these (never a live resolver in the package stage). An existing value
  // that differs from a fresh computation => fail loudly (a deploy changed the story under a live order).
  expectedPageCount    Int?
  storySourceHash      String?
  selectionFilename    String?
  frozenProductVersion String?
  fulfillmentVersion   Int      @default(1)  // logical delivery-event version; part of the Outbox dedupe key
  // Monotonic optimistic-concurrency token (P1-e2 B4). Bumped by any writer of delivery inputs
  // (text/frozen/assets/payload fields). The readiness manifest records the value it evaluated; the
  // Order→ready commit and the pre-send recheck are conditional on it being unchanged. Writer-side
  // bumps are wired in P1-f; until then it stays 0 (the guard is inert, never falsely suppresses).
  inputVersion         Int      @default(0)

  // Error tracking
  lastError          String?
  errorAt            DateTime?

  // Relations
  wizardSessionId    String?      @unique
  wizardSession      WizardSession? @relation(fields: [wizardSessionId], references: [id])
  book               GeneratedBook?
  payment            PaymentRecord?
  generationJob      GenerationJob?
  storyDirectionSet  StoryDirectionSet?
  resemblanceAudits  ResemblanceAudit[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserAccount {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?

  orders    Order[]
  sessions  UserSession[]
  otpCodes  OtpCode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  user      UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  user      UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  code      String
  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model ResemblanceAudit {
  id                    String   @id @default(cuid())
  orderId               String
  order                 Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pageNumber            Int?
  candidateIndex        Int?
  selected              Boolean  @default(false)
  seed                  Int?
  model                 String?
  styleId               String?
  resemblanceScore      Float?
  allCandidateScores    Float[]
  threshold             Float?
  minAcceptableScore    Float?
  softFailBand          Float?
  extremeMargin         Float?
  selectionGap          Float?
  resemblanceStatus     String?
  resemblanceConfidence String?
  inputStrength         String?
  sanityDisagreement    Boolean?
  lowDiversity          Boolean?
  extremeMismatch       Boolean?
  reason                String?
  reasonCodes           String[]
  faceDetectConfidence  Float?
  faceAreaRatio         Float?
  brightness            Float?
  sharpness             Float?
  source                String?
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([orderId, createdAt])
}

model StoryDirectionSet {
  id                  String                  @id @default(cuid())
  orderId             String                  @unique
  order               Order                   @relation(fields: [orderId], references: [id])
  selectedStyle       IllustrationStyle
  status              StoryDirectionSetStatus @default(pending)
  selectedDirectionId String?                 @unique
  selectedDirection   StoryDirection?         @relation("SelectedStoryDirection", fields: [selectedDirectionId], references: [id], onDelete: SetNull)
  directions          StoryDirection[]        @relation("StoryDirectionSetDirections")

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model StoryDirection {
  id                 String                 @id @default(cuid())
  directionSetId     String
  directionSet       StoryDirectionSet      @relation("StoryDirectionSetDirections", fields: [directionSetId], references: [id], onDelete: Cascade)
  archetype          StoryDirectionArchetype
  title              String
  summary            String                 @db.Text
  emotionalLabel     String
  storyPremise       String                 @db.Text
  openingScenePrompt String                 @db.Text
  previewImagePrompt String                 @db.Text
  previewImageUrl    String?
  previewImageRawUrl String?

  selectedBySet      StoryDirectionSet?     @relation("SelectedStoryDirection")

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([directionSetId, archetype])
}

// ─── GeneratedBook ────────────────────────────────────
model GeneratedBook {
  id          String   @id @default(cuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])

  title       String
  coverText   String?
  coverImageUrl String?
  pages       BookPage[]

  audioAsset  AudioAsset?
  pdfUrl      String?
  videoUrl    String?   // on-demand exported MP4 (full book slideshow + narration)

  readUrl     String?   // public read link
  expiresAt   DateTime? // if links expire

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── BookPage ─────────────────────────────────────────
model BookPage {
  id          String        @id @default(cuid())
  bookId      String
  book        GeneratedBook @relation(fields: [bookId], references: [id])

  pageNumber  Int
  text        String        @db.Text
  pageTemplate String?
  textZone    String?
  lighting    String?
  textColorScheme String?
  imageAsset  ImageAsset?

  // narration text (may differ from display text — sleep mode pacing etc)
  narrationText String?     @db.Text

  /// Per-page narration MP3 (ElevenLabs). Legacy books use AudioAsset on GeneratedBook only.
  audioUrl    String?

  createdAt   DateTime @default(now())
}

// ─── ImageAsset ───────────────────────────────────────
model ImageAsset {
  id          String    @id @default(cuid())
  pageId      String    @unique
  page        BookPage  @relation(fields: [pageId], references: [id])

  provider    String    // "dall-e-3" | "replicate" | "stability"
  prompt      String    @db.Text
  url         String    // stored URL (after saving to our storage)
  /// Reader/PDF-ready asset: edge-softened, paper-integrated treatment of `url` (null = use `url`)
  presentationUrl String?
  rawUrl      String?   // original provider URL
  width       Int?
  height      Int?
  style       String?
  /// orderId + artifactType + page + model + quality + generationVersion — skip duplicate paid gen
  idempotencyKey String? @unique

  createdAt   DateTime @default(now())
}

// ─── AudioAsset ───────────────────────────────────────
model AudioAsset {
  id          String        @id @default(cuid())
  bookId      String        @unique
  book        GeneratedBook @relation(fields: [bookId], references: [id])

  provider    String        // "elevenlabs"
  voiceId     String
  voiceLabel  String?
  sleepMode   Boolean       @default(false)
  url         String        // stored audio URL
  durationSec Float?

  createdAt   DateTime @default(now())
}

// ─── PaymentRecord ────────────────────────────────────
model PaymentRecord {
  id              String   @id @default(cuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id])

  provider        String   @default("stripe")
  stripeSessionId String?
  stripeEventId   String?
  amount          Int      // in agorot
  currency        String   @default("ils")
  paid            Boolean  @default(false)
  paidAt          DateTime?
  raw             Json?    // full stripe event payload

  createdAt       DateTime @default(now())
}

model StripeWebhookEvent {
  id          String   @id @default(cuid())
  stripeEventId String @unique
  eventType   String
  orderId     String?
  processedAt DateTime @default(now())
}

model PaymeWebhookEvent {
  id                 String   @id @default(cuid())
  paymeTransactionId String   @unique
  eventType          String
  orderId            String?
  processedAt        DateTime @default(now())
}

// ─── GenerationJob ────────────────────────────────────
model GenerationJob {
  id          String   @id @default(cuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])

  status      GenerationStatus @default(pending)
  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  attempts    Int      @default(0)
  lastError   String?

  // Stage tracking
  textDone    Boolean @default(false)
  imagesDone  Boolean @default(false)
  audioDone   Boolean @default(false)
  packaged    Boolean @default(false)

  /// Chunked pipeline: text | dna | cover | page_images | audio | video | package | done | failed
  currentStage       String   @default("pending")
  lockedBy           String?
  leaseExpiresAt     DateTime?
  generationVersion  Int      @default(1)
  provider           String?
  model              String?
  quality            String?
  triggerReason      String?
  retryable          Boolean  @default(false)

  // Reliability / recovery diagnostics (additive). The HTTP self-chain is best-effort;
  // durable recovery is the sweeper reclaiming expired leases. These make a silent chain
  // failure DB-visible and bound infinite re-spend on a stuck stage.
  staleReclaimCount  Int      @default(0)  // times the sweeper has reclaimed this job
  lastReclaimStage   String?              // progress fingerprint at last reclaim (stage:completedCount)
  lastChainStatus    Int?                 // HTTP status of the last self-chain kick (e.g. 401)
  lastChainError     String?              // last self-chain failure (host/status/body snippet)
  lastWorkerKickAt   DateTime?            // when the last self-chain kick was attempted
  /// Cached DNA / story paths between chunks (JSON)
  pipelineCache      Json?
  completedPageNumbers Json?
  failedPageNumbers    Json?
  pageAttempts         Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, leaseExpiresAt])
  @@index([currentStage])
}

// ─── Phase-1 base_book_integrity ──────────────────────
// IMMUTABLE per-evaluation record: one terminal INSERT with passed|blocked. evidence + status are NEVER
// mutated. The "current" readiness for an (order, scope) is the latest revision whose inputsHash still
// matches the current assets; an older passed Manifest stays passed but is no longer current (=> stale).
model BookReadinessManifest {
  id         String          @id @default(cuid())
  orderId    String
  scope      String          // e.g. "base_book"
  revision   Int             // atomically allocated; (orderId, scope, revision) is unique
  status     ReadinessStatus // only `passed` or `blocked` are ever written here
  inputsHash String          // hash of the inputs (assets + frozen text) this evaluation observed
  inputVersion Int           @default(0) // Order.inputVersion observed at evaluation time (P1-e2 B4 optimistic-concurrency)
  evidence   Json            // per-check evidence (decode/bytes/mime/sha per asset, page list, frozen truth…)
  reason     String?         // block reason (null when passed)
  createdAt  DateTime        @default(now())

  @@unique([orderId, scope, revision])
  @@index([orderId, scope])
}

// MUTABLE pointer to the current readiness state per (order, scope).
model BookReadiness {
  id                String          @id @default(cuid())
  orderId           String
  scope             String
  status            ReadinessStatus @default(pending)
  currentManifestId String?
  reason            String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([orderId, scope])
}

// Transactional outbox for customer deliveries (effectively-once). enqueue != send; a worker/cron drains
// it with an atomic lease and idempotent provider send. dedupeKey = a logical fulfillment event.
model DeliveryOutbox {
  id                String               @id @default(cuid())
  dedupeKey         String               @unique // book-ready/{orderId}/base-book/{fulfillmentVersion}
  orderId           String
  scope             String
  status            DeliveryOutboxStatus @default(scheduled)
  payload           Json
  payloadHash       String               // same dedupeKey + a different payloadHash => error, never send
  // (P1-f) Unambiguous binding of this delivery to the manifest + inputVersion it was enqueued under. The
  // send-time CAS verifies BookReadiness.currentManifestId === manifestId AND Order.inputVersion === inputVersion.
  // A re-commit REBINDS this row to the new manifest in place (same dedupeKey); enqueueDelivery ALWAYS sets both
  // on create and on rebind, so they are NOT NULL (#3h #6 — preflight: the table is empty everywhere).
  manifestId        String
  inputVersion      Int
  attempts          Int                  @default(0)
  nextAttemptAt     DateTime?
  leaseExpiresAt    DateTime?
  lastError         String?
  // Durable failure classification. With the P1-f pure-CAS path the ONLY value produced is send_ambiguous:
  //   a provider send was attempted and the result is unknown (Resend may have accepted) -> NEVER auto-roll
  //   (a new fulfillment = new idempotency key = bypasses the 24h dedup). The roll decision keys off
  //   sendAttempted, not this column. recheck_exhausted is LEGACY (the removed live-recheck path), no longer written.
  failureClass      String?
  // Durable "a provider send was EVER attempted on this row" (P1-e4 review C + P1-f). The single source of
  // truth for the rebind/reconciliation decision: a row is rebindable ONLY while sendAttempted is false.
  sendAttempted     Boolean              @default(false)
  // (P1-f #3h) Timestamp of the FIRST send attempt (set once, by the CAS, via COALESCE). Resend's 24h
  // idempotency window is measured from HERE, not createdAt: an order that sat 25h in the queue still gets its
  // first attempt; a re-attempt > 24h after the first becomes send_ambiguous (no blind resend).
  firstSendAttemptAt DateTime?
  providerMessageId String?
  createdAt         DateTime             @default(now())
  sentAt            DateTime?

  @@index([status, nextAttemptAt])
}
