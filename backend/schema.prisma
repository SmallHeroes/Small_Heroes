// Prisma Schema — גיבורים קטנים
// Run: npx prisma generate && npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────
enum OrderStatus {
  draft
  pending_payment
  paid
  generating
  ready
  failed
  partial // story+images ready but audio failed
}

enum GenerationStatus {
  pending
  running
  done
  failed
}

enum StoryDirectionArchetype {
  bedtime
  adventure
  fantasy
}

enum StoryDirectionSetStatus {
  pending
  ready
  selected
  failed
}

enum StoryLength {
  short   // 10 pages (bedtime tier)
  medium  // 15 pages (adventure tier)
  long    // 20 pages (fantasy tier)
}

enum IllustrationStyle {
  pencil_watercolor
  realistic_illustrated
  whimsical_comic_fantasy
  detailed_whimsical_world
  // Legacy — kept to avoid DB migration failures on old rows
  clean_cartoon_2d
  soft_3d_animation
  illustrative_classic
  realistic_cartoon
}

// ─── Customer ─────────────────────────────────────────
model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

// ─── WizardSession ────────────────────────────────────
// Stores raw wizard input before order creation
model WizardSession {
  id        String   @id @default(cuid())
  sessionId String   @unique  // browser session ID
  data      Json                // full wizard state blob
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order?
}

// ─── Order ────────────────────────────────────────────
model Order {
  id              String      @id @default(cuid())
  status          OrderStatus @default(draft)

  // Customer
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id])
  userId          String?
  user            UserAccount? @relation(fields: [userId], references: [id])
  customerEmail   String
  customerName    String

  // Child / story config
  childName         String
  childAge          Int?
  childGender       String?
  childTraits       String[]
  childSuperpower   String?   // single hero trait selected in wizard
  bookName          String?   // optional custom book title from wizard
  dedication        String?   @db.VarChar(300)
  childImageUrl     String?
  characterAnchors  Json?
  familyContext     Json?     // { parent1, parent2, sibling, homeText } — optional, from wizard step 4

  // Story parameters
  topic           String
  challengeItems  String[]
  challengeFree   String?
  outcomeItems    String[]
  outcomeFree     String?
  helperItems     String[]
  helperFree      String?
  avoidItems      String[]
  avoidFree       String?

  // Product configuration
  storyLength        StoryLength       @default(medium)
  /** Wizard package tier: bedtime | adventure | fantasy (matches pricing + page count). */
  storyDirection     String?
  coverImageUrl      String?
  illustrationStyle  IllustrationStyle @default(pencil_watercolor)
  audioEnabled       Boolean           @default(false)
  selectedVoice      String?
  sleepMode          Boolean           @default(false)
  pdfEnabled         Boolean           @default(false)
  bundleEnabled      Boolean           @default(false)
  videoEnabled       Boolean           @default(false)

  // Pricing
  basePrice          Int   // in agorot (ILS cents)
  addonsPrice        Int
  totalPrice         Int

  // Stripe
  stripeSessionId    String?  @unique
  stripePaymentId    String?
  stripePaid         Boolean  @default(false)
  stripeMetadata     Json?

  // Generic payment tracking (PayMe-first)
  paymentProvider    String?
  paymentId          String?
  paymeTransactionId String?  @unique
  paymeMetadata      Json?

  // Generation tracking
  textStatus         GenerationStatus @default(pending)
  imageStatus        GenerationStatus @default(pending)
  audioStatus        GenerationStatus @default(pending)
  packageStatus      GenerationStatus @default(pending)

  // Error tracking
  lastError          String?
  errorAt            DateTime?

  // Relations
  wizardSessionId    String?      @unique
  wizardSession      WizardSession? @relation(fields: [wizardSessionId], references: [id])
  book               GeneratedBook?
  payment            PaymentRecord?
  generationJob      GenerationJob?
  storyDirectionSet  StoryDirectionSet?
  resemblanceAudits  ResemblanceAudit[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserAccount {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?

  orders    Order[]
  sessions  UserSession[]
  otpCodes  OtpCode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  user      UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  user      UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  code      String
  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model ResemblanceAudit {
  id                    String   @id @default(cuid())
  orderId               String
  order                 Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  pageNumber            Int?
  candidateIndex        Int?
  selected              Boolean  @default(false)
  seed                  Int?
  model                 String?
  styleId               String?
  resemblanceScore      Float?
  allCandidateScores    Float[]
  threshold             Float?
  minAcceptableScore    Float?
  softFailBand          Float?
  extremeMargin         Float?
  selectionGap          Float?
  resemblanceStatus     String?
  resemblanceConfidence String?
  inputStrength         String?
  sanityDisagreement    Boolean?
  lowDiversity          Boolean?
  extremeMismatch       Boolean?
  reason                String?
  reasonCodes           String[]
  faceDetectConfidence  Float?
  faceAreaRatio         Float?
  brightness            Float?
  sharpness             Float?
  source                String?
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([orderId, createdAt])
}

model StoryDirectionSet {
  id                  String                  @id @default(cuid())
  orderId             String                  @unique
  order               Order                   @relation(fields: [orderId], references: [id])
  selectedStyle       IllustrationStyle
  status              StoryDirectionSetStatus @default(pending)
  selectedDirectionId String?                 @unique
  selectedDirection   StoryDirection?         @relation("SelectedStoryDirection", fields: [selectedDirectionId], references: [id], onDelete: SetNull)
  directions          StoryDirection[]        @relation("StoryDirectionSetDirections")

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model StoryDirection {
  id                 String                 @id @default(cuid())
  directionSetId     String
  directionSet       StoryDirectionSet      @relation("StoryDirectionSetDirections", fields: [directionSetId], references: [id], onDelete: Cascade)
  archetype          StoryDirectionArchetype
  title              String
  summary            String                 @db.Text
  emotionalLabel     String
  storyPremise       String                 @db.Text
  openingScenePrompt String                 @db.Text
  previewImagePrompt String                 @db.Text
  previewImageUrl    String?
  previewImageRawUrl String?

  selectedBySet      StoryDirectionSet?     @relation("SelectedStoryDirection")

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([directionSetId, archetype])
}

// ─── GeneratedBook ────────────────────────────────────
model GeneratedBook {
  id          String   @id @default(cuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])

  title       String
  coverText   String?
  coverImageUrl String?
  pages       BookPage[]

  audioAsset  AudioAsset?
  pdfUrl      String?
  videoUrl    String?   // on-demand exported MP4 (full book slideshow + narration)

  readUrl     String?   // public read link
  expiresAt   DateTime? // if links expire

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── BookPage ─────────────────────────────────────────
model BookPage {
  id          String        @id @default(cuid())
  bookId      String
  book        GeneratedBook @relation(fields: [bookId], references: [id])

  pageNumber  Int
  text        String        @db.Text
  pageTemplate String?
  textZone    String?
  lighting    String?
  textColorScheme String?
  imageAsset  ImageAsset?

  // narration text (may differ from display text — sleep mode pacing etc)
  narrationText String?     @db.Text

  /// Per-page narration MP3 (ElevenLabs). Legacy books use AudioAsset on GeneratedBook only.
  audioUrl    String?

  createdAt   DateTime @default(now())
}

// ─── ImageAsset ───────────────────────────────────────
model ImageAsset {
  id          String    @id @default(cuid())
  pageId      String    @unique
  page        BookPage  @relation(fields: [pageId], references: [id])

  provider    String    // "dall-e-3" | "replicate" | "stability"
  prompt      String    @db.Text
  url         String    // stored URL (after saving to our storage)
  /// Reader/PDF-ready asset: edge-softened, paper-integrated treatment of `url` (null = use `url`)
  presentationUrl String?
  rawUrl      String?   // original provider URL
  width       Int?
  height      Int?
  style       String?
  /// orderId + artifactType + page + model + quality + generationVersion — skip duplicate paid gen
  idempotencyKey String? @unique

  createdAt   DateTime @default(now())
}

// ─── AudioAsset ───────────────────────────────────────
model AudioAsset {
  id          String        @id @default(cuid())
  bookId      String        @unique
  book        GeneratedBook @relation(fields: [bookId], references: [id])

  provider    String        // "elevenlabs"
  voiceId     String
  voiceLabel  String?
  sleepMode   Boolean       @default(false)
  url         String        // stored audio URL
  durationSec Float?

  createdAt   DateTime @default(now())
}

// ─── PaymentRecord ────────────────────────────────────
model PaymentRecord {
  id              String   @id @default(cuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id])

  provider        String   @default("stripe")
  stripeSessionId String?
  stripeEventId   String?
  amount          Int      // in agorot
  currency        String   @default("ils")
  paid            Boolean  @default(false)
  paidAt          DateTime?
  raw             Json?    // full stripe event payload

  createdAt       DateTime @default(now())
}

model StripeWebhookEvent {
  id          String   @id @default(cuid())
  stripeEventId String @unique
  eventType   String
  orderId     String?
  processedAt DateTime @default(now())
}

model PaymeWebhookEvent {
  id                 String   @id @default(cuid())
  paymeTransactionId String   @unique
  eventType          String
  orderId            String?
  processedAt        DateTime @default(now())
}

// ─── GenerationJob ────────────────────────────────────
model GenerationJob {
  id          String   @id @default(cuid())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])

  status      GenerationStatus @default(pending)
  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  attempts    Int      @default(0)
  lastError   String?

  // Stage tracking
  textDone    Boolean @default(false)
  imagesDone  Boolean @default(false)
  audioDone   Boolean @default(false)
  packaged    Boolean @default(false)

  /// Chunked pipeline: text | dna | cover | page_images | audio | video | package | done | failed
  currentStage       String   @default("pending")
  lockedBy           String?
  leaseExpiresAt     DateTime?
  generationVersion  Int      @default(1)
  provider           String?
  model              String?
  quality            String?
  triggerReason      String?
  retryable          Boolean  @default(false)
  /// Cached DNA / story paths between chunks (JSON)
  pipelineCache      Json?
  completedPageNumbers Json?
  failedPageNumbers    Json?
  pageAttempts         Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, leaseExpiresAt])
  @@index([currentStage])
}
